# Copiar este archivo como .env.local y completar los valores reales.
# .env.local NUNCA se commitea al repo.
#
# Prefijo VITE_ es obligatorio para que Vite exponga la variable en el cliente.
# En Vercel, configurar las mismas variables SIN el prefijo VITE_ (server-side).

# ── Desarrollo local (llamadas directas desde el browser) ─────────────────────
VITE_ANTHROPIC_API_KEY=sk-ant-...
VITE_ALPHA_VANTAGE_API_KEY=TU_KEY_AQUI

# Para Yahoo Finance local necesitás un proxy CORS.
# Opción rápida: npx cors-anywhere → http://localhost:8080
VITE_YAHOO_FINANCE_PROXY=http://localhost:8080/https://query1.finance.yahoo.com

# ── Producción en Vercel (dejar los VITE_ vacíos, usar las server-side) ───────
# En el dashboard de Vercel → Settings → Environment Variables:
#
#   ANTHROPIC_API_KEY     = sk-ant-...   (sin prefijo VITE_, solo server-side)
#   ALPHA_VANTAGE_API_KEY = TU_KEY       (sin prefijo VITE_, solo server-side)
#   VITE_YAHOO_FINANCE_PROXY = /api/yahoo  (con prefijo VITE_, se bake en el build)
#
# Con esta config en Vercel:
#   - VITE_ANTHROPIC_API_KEY y VITE_ALPHA_VANTAGE_API_KEY = vacíos → el componente
#     usa los proxies /api/claude y /api/alpha automáticamente
#   - VITE_YAHOO_FINANCE_PROXY = /api/yahoo → rewrite de vercel.json lo resuelve
